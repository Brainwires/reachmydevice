# OpenReach host agent config (copy to ~/.config/openreach/host.env, chmod 600).
# Obtain the token from the web console: register this machine as a device.
OPENREACH_RENDEZVOUS_URL=wss://openreach.brainwires.dev/ws
OPENREACH_ICE=stun:stun.l.google.com:19302

# --- Device token ------------------------------------------------------------
# PREFERRED: put the token in a 0600 file (not this env), so it doesn't show up
# in `ps e` / /proc/<pid>/environ. Default path ~/.config/openreach/token.
#   printf '%s' 'replace-with-device-token' > ~/.config/openreach/token
#   chmod 600 ~/.config/openreach/token
# OPENREACH_TOKEN_FILE=%h/.config/openreach/token
# Fallback (discouraged): OPENREACH_TOKEN=replace-with-device-token

# --- Identity key at rest ----------------------------------------------------
# Set a passphrase to encrypt the device identity key on disk (Argon2id +
# XChaCha20-Poly1305). Without it the key is stored in plaintext (0600). Keep the
# passphrase out of this file in high-assurance setups (e.g. a systemd credential).
# OPENREACH_KEY_PASSPHRASE=change-me

OPENREACH_NAME=my-host
OPENREACH_WIDTH=1920
OPENREACH_HEIGHT=1080
OPENREACH_FPS=30
OPENREACH_BITRATE=8000000

# --- Unattended access -------------------------------------------------------
# STRONGLY RECOMMENDED for always-on hosts: only listed devices may connect.
# List authorized viewer device_ids (one 32-hex-char id per line) in this file;
# each viewer shows its device_id in the app / web console. Its presence turns
# enforcement on automatically. Alternatively set OPENREACH_REQUIRE_AUTH=1 (and
# an empty list refuses everyone — a safe default).
OPENREACH_AUTHORIZED_KEYS=%h/.config/openreach/authorized_keys
# OPENREACH_REQUIRE_AUTH=1

# --- Optional features (off by default) --------------------------------------
# OPENREACH_AUDIO=1        # stream host audio (Opus); see docs/CHANGELOG caveats
# OPENREACH_TRAY=1         # desktop tray companion (build with --features tray)
# RUST_LOG=info
