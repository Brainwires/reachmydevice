# ReachMyDevice host agent config (copy to ~/.config/rmd/host.env, chmod 600).
# Obtain the token from the web console: register this machine as a device.
RMD_RENDEZVOUS_URL=wss://openreach.brainwires.dev/ws
RMD_ICE=stun:stun.l.google.com:19302

# --- Device token ------------------------------------------------------------
# PREFERRED: put the token in a 0600 file (not this env), so it doesn't show up
# in `ps e` / /proc/<pid>/environ. Default path ~/.config/rmd/token.
#   printf '%s' 'replace-with-device-token' > ~/.config/rmd/token
#   chmod 600 ~/.config/rmd/token
# RMD_TOKEN_FILE=%h/.config/rmd/token
# Fallback (discouraged): RMD_TOKEN=replace-with-device-token

# --- Identity key at rest ----------------------------------------------------
# Set a passphrase to encrypt the device identity key on disk (Argon2id +
# XChaCha20-Poly1305). Without it the key is stored in plaintext (0600). Keep the
# passphrase out of this file in high-assurance setups (e.g. a systemd credential).
# RMD_KEY_PASSPHRASE=change-me

RMD_NAME=my-host
RMD_WIDTH=1920
RMD_HEIGHT=1080
RMD_FPS=30
RMD_BITRATE=8000000

# --- Unattended access -------------------------------------------------------
# STRONGLY RECOMMENDED for always-on hosts: only listed devices may connect.
# List authorized viewer device_ids (one 32-hex-char id per line) in this file;
# each viewer shows its device_id in the app / web console. Its presence turns
# enforcement on automatically. Alternatively set RMD_REQUIRE_AUTH=1 (and
# an empty list refuses everyone — a safe default).
RMD_AUTHORIZED_KEYS=%h/.config/rmd/authorized_keys
# RMD_REQUIRE_AUTH=1

# --- Optional features (off by default) --------------------------------------
# RMD_AUDIO=1        # stream host audio (Opus); see docs/CHANGELOG caveats
# RMD_TRAY=1         # desktop tray companion (build with --features tray)
# RUST_LOG=info
