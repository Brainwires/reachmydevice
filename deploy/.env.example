# Copy to .env and edit. Used by docker-compose.

# Public domain pointing at this VPS (A/AAAA record). Caddy gets a cert for it,
# and it is the TURN realm.
RMD_DOMAIN=rmd.example.com

# TURN relay is OFF by default (STUN-only = pure peer-to-peer, no server
# bandwidth). Set to true ONLY if you accept that relayed media — the fallback
# for peers that can't connect directly — flows through and uses this server's
# bandwidth. When false, the settings below are ignored.
RMD_TURN_ENABLED=false

# Shared secret for TURN credential minting. Generate with:
#   openssl rand -hex 32
# Must be identical for rendezvous and coturn.
TURN_SECRET=change-me-to-a-long-random-hex-string

# The address clients dial for STUN/TURN. Must be the coturn host's DIRECT public
# IP (or a DNS-only / grey-cloud hostname) — NOT a Cloudflare-proxied domain,
# which never reaches the UDP relay. Usually the same value as EXTERNAL_IP below.
# Leave blank to serve STUN-only (no relay; cross-NAT peers may not connect).
RMD_TURN_HOST=203.0.113.10
# TURN/STUN listener port (coturn default). Open this + the relay range at BOTH
# the OS firewall AND your cloud provider's firewall (see docker-compose.yml).
RMD_TURN_PORT=3478
# coturn advertises this as the relay candidate address (its own public IP).
RMD_TURN_EXTERNAL_IP=203.0.113.10

# Public account registration is CLOSED by default (secure by default).
# Set to true only long enough to create your account, then remove/disable it.
# RMD_RZ_OPEN_REGISTRATION=true
