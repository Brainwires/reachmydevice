# Copy to .env and edit. Used by docker-compose.

# Public domain pointing at this VPS (A/AAAA record). Caddy gets a cert for it,
# and it is the TURN realm.
RMD_DOMAIN=rmd.example.com

# Shared secret for TURN credential minting. Generate with:
#   openssl rand -hex 32
# Must be identical for rendezvous and coturn.
TURN_SECRET=change-me-to-a-long-random-hex-string

# Public account registration is CLOSED by default (secure by default).
# Set to true only long enough to create your account, then remove/disable it.
# RMD_RZ_OPEN_REGISTRATION=true
